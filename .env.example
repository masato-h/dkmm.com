# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DeepSeek_API_KEY=

# Search
BRAVE_API_KEY=

# X (Twitter) API — OAuth 2.0 User Context (PKCE)
# https://console.x.com/ で OAuth 2.0 を有効化、Confidential client を選択、
# Callback URL に http://127.0.0.1:8080/callback を登録すること
# 2026/2以降は Pay-Per-Use がデフォルト。Console で spending limit 設定推奨
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8080/callback
